    "vue": "^3.5.13",
    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.4.14",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "postcss": "^8.4.5",
    "tailwindcss": "^3.4.15",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0"
